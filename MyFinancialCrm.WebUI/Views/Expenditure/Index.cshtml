@model List<FinancialCrm.EntityLayer.Concrete.Expend>
@{
    ViewData["Title"] = "Expenditures";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .page-title {
        font-family: 'Playfair Display', serif;
        font-size: 26px;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 4px;
    }

    .page-sub {
        font-size: 13px;
        color: #94a3b8;
        margin-bottom: 28px;
    }

    .add-bar {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #eef0f5;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04);
        padding: 20px 24px;
        margin-bottom: 24px;
    }

    .add-bar-title {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #94a3b8;
        margin-bottom: 14px;
    }

    .crm-input, .crm-select {
        background: #f8fafc;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        padding: 11px 14px;
        font-size: 13px;
        color: #0f172a;
        outline: none;
        width: 100%;
        transition: border-color 0.2s, box-shadow 0.2s;
        font-family: inherit;
    }

        .crm-input:focus, .crm-select:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99,102,241,0.1);
            background: #fff;
        }

        .crm-input::placeholder {
            color: #cbd5e1;
        }

    .crm-select {
        appearance: none;
        cursor: pointer;
    }

    .btn-add {
        width: 100%;
        padding: 11px;
        background: linear-gradient(135deg, #6366f1, #818cf8);
        border: none;
        border-radius: 10px;
        color: #fff;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.15s;
    }

        .btn-add:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }

    .crm-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #eef0f5;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04);
        overflow: hidden;
    }

    .crm-card-header {
        padding: 18px 24px;
        border-bottom: 1px solid #f1f5f9;
    }

        .crm-card-header .title {
            font-family: 'Playfair Display', serif;
            font-size: 16px;
            font-weight: 600;
            color: #0f172a;
        }

    .crm-table {
        width: 100%;
        border-collapse: collapse;
    }

        .crm-table thead th {
            padding: 12px 24px;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: #94a3b8;
            background: #f8fafc;
            border-bottom: 1px solid #eef0f5;
        }

        .crm-table tbody td {
            padding: 14px 24px;
            font-size: 13px;
            color: #334155;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
        }

        .crm-table tbody tr:last-child td {
            border-bottom: none;
        }

        .crm-table tbody tr:hover td {
            background: #f8fafc;
        }

    .exp-title {
        font-weight: 600;
        color: #0f172a;
    }

    .exp-amount {
        font-weight: 700;
        color: #e11d48;
    }

    .date-badge {
        display: inline-block;
        background: #f1f5f9;
        color: #64748b;
        border-radius: 6px;
        padding: 3px 10px;
        font-size: 11px;
        font-weight: 500;
    }

    .btn-del {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        border-radius: 8px;
        padding: 5px 12px;
        font-size: 12px;
        font-weight: 500;
        border: 1.5px solid #fda4af;
        color: #e11d48;
        background: #fff1f2;
        text-decoration: none;
        transition: background 0.15s;
    }

        .btn-del:hover {
            background: #ffe4e6;
        }
</style>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">

<div class="page-title">Expenditures</div>
<div class="page-sub">Log and monitor all spending</div>

<!-- Add Expend -->
<div class="add-bar">
    <div class="add-bar-title">Add New Expense</div>
    <form method="post" action="/Expenditure/CreateExpenditure">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <input type="text" name="ExpendTitle" class="crm-input" placeholder="Expense name" required />
            </div>
            <div class="col-md-2">
                <input type="number" step="0.01" name="ExpendAmount" class="crm-input" placeholder="Amount" required />
            </div>
            <div class="col-md-3">
                <select name="CategoryId" class="crm-select" required>
                    <option value="">Choose category...</option>
                    @if (ViewBag.Categories != null)
                    {
                        foreach (var category in (List<FinancialCrm.EntityLayer.Concrete.Category>)ViewBag.Categories)
                        {
                            <option value="@category.CategoryId">@category.CategoryName</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <input type="date" name="ExpendDate" class="crm-input" required />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn-add">+ Add</button>
            </div>
        </div>
    </form>
</div>

<!-- Table -->
<div class="crm-card">
    <div class="crm-card-header">
        <div class="title">All Expenditures</div>
    </div>
    <table class="crm-table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Description</th>
                <th>Amount</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><span class="date-badge">@item.ExpendDate.ToShortDateString()</span></td>
                    <td class="exp-title">@item.ExpendTitle</td>
                    <td class="exp-amount">−@item.ExpendAmount.ToString("C2")</td>
                    <td>
                        <a href="/Expenditure/DeleteExpenditure/@item.ExpendId" class="btn-del">🗑 Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

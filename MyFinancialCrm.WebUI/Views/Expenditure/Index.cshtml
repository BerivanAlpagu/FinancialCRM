@model List<FinancialCrm.EntityLayer.Concrete.Expend>
@{
    ViewData["Title"] = "Harcamalar";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="card shadow mb-4 border-left-warning">
            <div class="card-header bg-warning text-dark">Yeni Harcama Ekle</div>
            <div class="card-body">
                <form method="post" action="/Expenditure/CreateExpenditure">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <input type="text" name="ExpendTitle" class="form-control" placeholder="Harcama Adı" required />
                        </div>
                        <div class="col-md-2">
                            <input type="number" step="0.01" name="ExpendAmount" class="form-control" placeholder="Tutar" required />
                        </div>
                        <div class="col-md-3">
                            <select name="CategoryId" class="form-select" required>
                                <option value="">Kategori Seçin...</option>
                                @if (ViewBag.Categories != null)
                                {
                                    foreach (var category in (List<FinancialCrm.EntityLayer.Concrete.Category>)ViewBag.Categories)
                                    {
                                        <option value="@category.CategoryId">@category.CategoryName</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <input type="date" name="ExpendDate" class="form-control" required />
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-warning w-100 font-weight-bold">Ekle</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="card shadow">
            <div class="card-body">
                <table class="table table-hover text-center">
                    <thead class="table-secondary">
                        <tr>
                            <th>Tarih</th>
                            <th>Açıklama</th>
                            <th>Tutar</th>
                            <th>İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.ExpendDate.ToShortDateString()</td>
                                <td>@item.ExpendTitle</td>
                                <td class="text-danger fw-bold">-@item.ExpendAmount.ToString("C2")</td>
                                <td>
                                    <a href="/Expenditure/DeleteExpenditure/@item.ExpendId" class="btn btn-sm btn-link text-danger p-0">Sil</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
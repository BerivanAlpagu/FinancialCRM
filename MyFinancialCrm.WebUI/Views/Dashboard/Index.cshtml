@model List<FinancialCrm.EntityLayer.Concrete.Expend>
@{
    ViewData["Title"] = "Financial Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .dash-stat-card {
        background: #fff;
        border-radius: 16px;
        padding: 28px 32px;
        border: 1px solid #eef0f5;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04);
        position: relative;
        overflow: hidden;
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .dash-stat-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.08);
        }

        .dash-stat-card .card-accent {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            border-radius: 16px 16px 0 0;
        }

    .accent-teal {
        background: linear-gradient(90deg, #0d9488, #14b8a6);
    }

    .accent-amber {
        background: linear-gradient(90deg, #d97706, #f59e0b);
    }

    .accent-rose {
        background: linear-gradient(90deg, #e11d48, #f43f5e);
    }

    .stat-label {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #94a3b8;
        margin-bottom: 10px;
    }

    .stat-value {
        font-family: 'Playfair Display', serif;
        font-size: 36px;
        font-weight: 700;
        color: #0f172a;
        line-height: 1;
        margin-bottom: 6px;
    }

    .stat-sub {
        font-size: 12px;
        color: #94a3b8;
    }

    .stat-icon {
        position: absolute;
        right: 28px;
        top: 28px;
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }

    .icon-teal {
        background: #f0fdfa;
        color: #0d9488;
    }

    .icon-amber {
        background: #fffbeb;
        color: #d97706;
    }

    .icon-rose {
        background: #fff1f2;
        color: #e11d48;
    }

    .section-title {
        font-family: 'Playfair Display', serif;
        font-size: 18px;
        font-weight: 600;
        color: #0f172a;
        margin-bottom: 4px;
    }

    .section-sub {
        font-size: 12px;
        color: #94a3b8;
        margin-bottom: 0;
    }

    .crm-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #eef0f5;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04);
        overflow: hidden;
    }

    .crm-card-header {
        padding: 20px 28px;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .crm-table {
        width: 100%;
        border-collapse: collapse;
    }

        .crm-table thead th {
            padding: 12px 28px;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: #94a3b8;
            background: #f8fafc;
            border-bottom: 1px solid #eef0f5;
        }

        .crm-table tbody td {
            padding: 14px 28px;
            font-size: 13px;
            color: #334155;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
        }

        .crm-table tbody tr:last-child td {
            border-bottom: none;
        }

        .crm-table tbody tr:hover td {
            background: #f8fafc;
        }

    .amount-neg {
        color: #e11d48;
        font-weight: 600;
    }

    .badge-date {
        display: inline-block;
        background: #f1f5f9;
        color: #64748b;
        border-radius: 6px;
        padding: 3px 10px;
        font-size: 11px;
        font-weight: 500;
    }
</style>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">

<!-- Stat Cards -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="dash-stat-card">
            <div class="card-accent accent-teal"></div>
            <div class="stat-icon icon-teal">💰</div>
            <div class="stat-label">Total Balance</div>
            <div class="stat-value">@ViewBag.TotalBalance</div>
            <div class="stat-sub">Across all bank accounts</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="dash-stat-card">
            <div class="card-accent accent-amber"></div>
            <div class="stat-icon icon-amber">📋</div>
            <div class="stat-label">Active Bills</div>
            <div class="stat-value">@ViewBag.BillCount</div>
            <div class="stat-sub">Pending payments</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="dash-stat-card">
            <div class="card-accent accent-rose"></div>
            <div class="stat-icon icon-rose">📉</div>
            <div class="stat-label">Recent Expenses</div>
            <div class="stat-value">@Model.Count</div>
            <div class="stat-sub">Total transactions</div>
        </div>
    </div>
</div>

<!-- Recent Expenditures + Chart -->
<div class="row g-4">
    <div class="col-md-8">
        <div class="crm-card">
            <div class="crm-card-header">
                <div>
                    <div class="section-title">Recent Expenditures</div>
                    <p class="section-sub">Latest spending records</p>
                </div>
            </div>
            <table class="crm-table">
                <thead>
                    <tr>
                        <th>Description</th>
                        <th>Amount</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ExpendTitle</td>
                            <td class="amount-neg">−@item.ExpendAmount.ToString("C2")</td>
                            <td><span class="badge-date">@item.ExpendDate.ToShortDateString()</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="col-md-4">
        <div class="crm-card h-100">
            <div class="crm-card-header">
                <div>
                    <div class="section-title">Bank Distribution</div>
                    <p class="section-sub">Balance by account</p>
                </div>
            </div>
            <div style="padding: 24px;">
                <canvas id="myPieChart" style="max-height: 260px;"></canvas>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    var bankNames = @Html.Raw(Json.Serialize(ViewBag.BankNames));
    var bankBalances = @Html.Raw(Json.Serialize(ViewBag.BankBalances));
    var ctx = document.getElementById('myPieChart').getContext('2d');
    new Chart(ctx, {
        type: 'doughnut',
        data: {
            labels: bankNames,
            datasets: [{
                data: bankBalances,
                backgroundColor: ['#0d9488','#f59e0b','#6366f1','#f43f5e','#10b981'],
                borderWidth: 0,
                hoverOffset: 6
            }]
        },
        options: {
            maintainAspectRatio: false,
            cutout: '65%',
            plugins: {
                legend: { position: 'bottom', labels: { padding: 16, font: { size: 12 } } }
            }
        }
    });
</script>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Financial CRM</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>
        *, *::before, *::after {
            box-sizing: border-box;
        }

        :root {
            --sidebar-w: 248px;
            --bg: #f4f6fb;
            --surface: #ffffff;
            --border: #e8ecf2;
            --text-primary: #0f172a;
            --text-muted: #8a96a8;
            --accent: #3b6cf4;
            --accent-light: #eef1fe;
            --danger: #e11d48;
            --success: #0d9488;
            --amber: #d97706;
            --sidebar-bg: #0f172a;
            --sidebar-text: #8a96a8;
            --sidebar-hover: rgba(255,255,255,0.07);
            --sidebar-active-bg: rgba(59,108,244,0.18);
            --sidebar-active-text: #7ea6ff;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            display: flex;
            min-height: 100vh;
            margin: 0;
        }

        /* ── SIDEBAR ── */
        .sidebar {
            width: var(--sidebar-w);
            background: var(--sidebar-bg);
            min-height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            display: flex;
            flex-direction: column;
            z-index: 100;
            border-right: 1px solid rgba(255,255,255,0.04);
        }

        .sidebar-brand {
            padding: 20px 20px 16px;
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }

        .sidebar-logo-mark {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg, #3b6cf4, #60a5fa);
            border-radius: 10px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            color: #fff;
            margin-right: 10px;
            flex-shrink: 0;
        }

        .sidebar-brand-text {
            display: flex;
            flex-direction: column;
        }

        .brand-name {
            font-family: 'Playfair Display', serif;
            font-size: 16px;
            font-weight: 700;
            color: #fff;
            letter-spacing: 0.02em;
            line-height: 1.1;
        }

        .brand-sub {
            font-size: 10px;
            color: var(--sidebar-text);
            letter-spacing: 0.12em;
            text-transform: uppercase;
        }

        .sidebar-section-label {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.2);
            padding: 14px 20px 6px;
        }

        .sidebar nav {
            flex: 1;
            padding: 4px 10px;
        }

        .sidebar a {
            color: var(--sidebar-text);
            text-decoration: none;
            padding: 11px 14px;
            margin-bottom: 1px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 14px;
            font-weight: 500;
            transition: background 0.2s, color 0.2s;
            position: relative;
        }

            .sidebar a .nav-icon {
                width: 20px;
                text-align: center;
                font-size: 14px;
                flex-shrink: 0;
            }

            .sidebar a:hover {
                background: var(--sidebar-hover);
                color: #e2e8f0;
            }

            .sidebar a.active {
                background: var(--sidebar-active-bg);
                color: var(--sidebar-active-text);
            }

                .sidebar a.active .nav-icon {
                    color: var(--sidebar-active-text);
                }

        .sidebar-divider {
            height: 1px;
            background: rgba(255,255,255,0.06);
            margin: 12px 12px;
        }

        .sidebar-logout {
            padding: 16px 12px;
        }

            .sidebar-logout a {
                color: #f87171 !important;
                background: rgba(248,113,113,0.08) !important;
            }

                .sidebar-logout a:hover {
                    background: rgba(248,113,113,0.15) !important;
                }

        /* ── MAIN WRAPPER ── */
        .main-wrapper {
            margin-left: var(--sidebar-w);
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* ── TOPBAR ── */
        .topbar {
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            padding: 0 32px;
            height: 62px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 50;
        }

        .topbar-breadcrumb {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            color: var(--text-muted);
        }

            .topbar-breadcrumb .sep {
                color: var(--border);
            }

            .topbar-breadcrumb .current {
                color: var(--text-primary);
                font-weight: 600;
            }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .user-chip {
            display: flex;
            align-items: center;
            gap: 10px;
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: 40px;
            padding: 5px 14px 5px 5px;
        }

            .user-chip img {
                width: 30px;
                height: 30px;
                border-radius: 50%;
            }

        .user-chip-name {
            font-size: 13px;
            font-weight: 500;
            color: var(--text-primary);
        }

        /* ── CONTENT ── */
        .main-content {
            padding: 32px;
            flex: 1;
        }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="sidebar-brand d-flex align-items-center">
            <div class="sidebar-logo-mark">₣</div>
            <div class="sidebar-brand-text">
                <div class="brand-name">Finance CRM</div>
                <div class="brand-sub">Management Suite</div>
            </div>
        </div>

        <nav>
            <div class="sidebar-section-label">Main</div>
            <a asp-controller="Dashboard" asp-action="Index">
                <span class="nav-icon"><i class="fa fa-chart-pie"></i></span> Dashboard
            </a>
            <a asp-controller="Bank" asp-action="Index">
                <span class="nav-icon"><i class="fa fa-university"></i></span> Banks
            </a>

            <div class="sidebar-section-label">Finance</div>
            <a asp-controller="Bill" asp-action="Index">
                <span class="nav-icon"><i class="fa fa-file-invoice-dollar"></i></span> Bills
            </a>
            <a asp-controller="Expenditure" asp-action="Index">
                <span class="nav-icon"><i class="fa fa-credit-card"></i></span> Expenditures
            </a>
            <a asp-controller="Category" asp-action="Index">
                <span class="nav-icon"><i class="fa fa-tags"></i></span> Categories
            </a>
        </nav>

        <div class="sidebar-divider"></div>

        <div class="sidebar-logout">
            <a asp-controller="Login" asp-action="Logout">
                <span class="nav-icon"><i class="fa fa-sign-out-alt"></i></span> Logout
            </a>
        </div>
    </div>

    <!-- MAIN -->
    <div class="main-wrapper">

        <!-- TOPBAR -->
        <div class="topbar">
            <div class="topbar-breadcrumb">
                <span>App</span>
                <span class="sep">/</span>
                <span class="current">@ViewContext.RouteData.Values["controller"]</span>
            </div>
            <div class="topbar-right">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="user-chip">
                        <img src="https://ui-avatars.com/api/?name=@(User.Identity?.Name ?? "User")&background=3b6cf4&color=fff" alt="avatar" />
                        <span class="user-chip-name">@(User.Identity?.Name ?? "User")</span>
                    </div>
                }
                else
                {
                    <div class="user-chip">
                        <img src="https://ui-avatars.com/api/?name=Guest&background=94a3b8&color=fff" alt="avatar" />
                        <span class="user-chip-name">Guest</span>
                    </div>
                }
            </div>
        </div>

        <!-- PAGE CONTENT -->
        <div class="main-content">
            <div class="container-fluid px-0">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            Swal.fire({
                title: 'Success!',
                text: '@TempData["SuccessMessage"]',
                icon: 'success',
                confirmButtonText: 'OK',
                timer: 3000,
                confirmButtonColor: '#3b6cf4'
            });
        </script>
    }

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const currentPath = location.pathname.toLowerCase();
            document.querySelectorAll('.sidebar a').forEach(link => {
                const href = (link.getAttribute('href') || '').toLowerCase();
                if (href && currentPath.startsWith(href) && href !== '/') {
                    link.classList.add('active');
                }
            });
        });

        function confirmDelete(id, controller) {
            Swal.fire({
                title: 'Are you sure?',
                text: "This record will be permanently deleted.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#e11d48',
                cancelButtonColor: '#3b6cf4',
                confirmButtonText: 'Yes, delete',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = `/${controller}/Delete${controller}/${id}`;
                }
            });
        }
    </script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Financial CRM - Dashboard</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.min.css">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f4f7f6; /* Hafif soft bir gri */
            color: #2d3436;
        }

        /* Yan Menü (Sidebar) Tasarımı */
        .sidebar {
            background: linear-gradient(180deg, #1e293b 0%, #0f172a 100%);
            min-height: 100vh;
            box-shadow: 4px 0 10px rgba(0,0,0,0.1);
        }

            .sidebar a {
                color: #94a3b8;
                transition: all 0.3s;
                border-radius: 8px;
                margin: 5px 15px;
            }

                .sidebar a:hover, .sidebar a.active {
                    background: rgba(255,255,255,0.1);
                    color: #fff;
                }

        /* Kart (Card) Tasarımı - Wow Efekti */
        .card {
            border: none;
            border-radius: 12px;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        }

            .card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
            }

        /* Butonlar */
        .btn-primary {
            background-color: #3b82f6;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            font-weight: 500;
        }
    </style>
</head>
<body>

    <div class="sidebar">
        <div class="p-4 text-center border-bottom border-secondary">
            <h4>Financial CRM</h4>
        </div>
        <nav class="mt-3">
            <a href="/Dashboard/Index" class="active"><i class="fa fa-home me-2"></i> Dashboard</a>
            <a href="/Bank/Index"><i class="fa fa-university me-2"></i> Banks</a>
            <a href="/Bill/Index"><i class="fa fa-file-invoice me-2"></i> Bills</a>
            <a href="/Expenditure/Index"><i class="fa fa-credit-card me-2"></i> Expenditures</a>
            <a href="/Category/Index"><i class="fa fa-tags me-2"></i> Categories</a>
            <hr class="mx-3 border-secondary">
            <a href="/Login/Logout" class="text-danger">
                <i class="fa fa-sign-out-alt"></i> Logout
            </a>
        </nav>
    </div>

    <nav class="navbar navbar-expand-lg px-4 py-3">
        <div class="container-fluid">
            <span class="navbar-brand mb-0 h1 text-dark">
                Welcome, @(User.Identity?.Name ?? "Guest")
            </span>
            <div class="ms-auto d-flex align-items-center">
                <span class="navbar-brand mb-0 h1 text-dark">Welcome, @(User.Identity?.Name ?? "Guest")</span>

                <img src="https://ui-avatars.com/api/?name=@(User.Identity?.Name ?? "User")&background=3498db&color=fff"
                     class="rounded-circle" width="35" />
            </div>
        </div>
    </nav>

    <div class="main-content">
        <div class="container-fluid">
            @RenderBody()
            @if (TempData["SuccessMessage"] != null)
            {
                <script>
                    Swal.fire({
                        title: 'Successed!',
                        text: '@TempData["SuccessMessage"]',
                        icon: 'success',
                        confirmButtonText: 'Okay',
                        timer: 3000 // 3 saniye sonra kendi kapansın
                    });
                </script>
            }
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // Sayfa yüklendiğinde aktif menüyü boyar
        document.addEventListener("DOMContentLoaded", function() {
            const currentLocation = location.pathname;
            const menuItems = document.querySelectorAll('.sidebar a');
            menuItems.forEach(item => {
                if(item.getAttribute('href') === currentLocation){
                    item.classList.add('active');
                }
            });
        });

        function confirmDelete(id, controller) {
            Swal.fire({
                title: 'Are you sure?',
                text: "This record will be permanently deleted!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, delete it!',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = `/${controller}/Delete${controller}/${id}`;
                }
            })
        }
    </script>
</body>
</html>
@model List<FinancialCrm.EntityLayer.Concrete.Category>
@{
    ViewData["Title"] = "Category Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="card shadow mb-4">
            <div class="card-header bg-success text-white">Add New Category</div>
            <div class="card-body">
                <form method="post" action="/Category/CreateCategory">
                    <div class="row g-3">
                        <div class="col-md-9">
                            <input type="text" name="CategoryName" class="form-control" placeholder="Category Name (e.g., Grocery, Education...)" required />
                        </div>
                        <div class="col-md-3">
                            <button type="submit" class="btn btn-success w-100">Create Category</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="card shadow">
            <div class="card-body">
                <table class="table table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Category Name</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.CategoryId</td>
                                <td>@item.CategoryName</td>
                                <td>
                                    <a href="/Category/DeleteCategory/@item.CategoryId" class="btn btn-sm btn-outline-danger">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
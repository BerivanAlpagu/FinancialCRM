@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In — Financial CRM</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            min-height: 100vh;
            display: flex;
            background: #f4f6fb;
        }

        /* ── LEFT DECORATIVE PANEL ── */
        .left-panel {
            flex: 1;
            background: #0f172a;
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 64px;
            overflow: hidden;
        }

            /* Subtle dot grid */
            .left-panel::before {
                content: '';
                position: absolute;
                inset: 0;
                background-image: radial-gradient(circle, rgba(255,255,255,0.06) 1px, transparent 1px);
                background-size: 28px 28px;
            }

            /* Glow blob */
            .left-panel::after {
                content: '';
                position: absolute;
                width: 500px;
                height: 500px;
                border-radius: 50%;
                background: radial-gradient(circle, rgba(59,108,244,0.18) 0%, transparent 70%);
                top: -100px;
                left: -100px;
                pointer-events: none;
            }

        .left-content {
            position: relative;
            z-index: 2;
            max-width: 420px;
        }

        .brand-row {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 56px;
        }

        .brand-mark {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, #3b6cf4, #60a5fa);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            color: #fff;
            font-family: serif;
        }

        .brand-name {
            font-family: 'Playfair Display', serif;
            font-size: 17px;
            font-weight: 700;
            color: #fff;
            letter-spacing: 0.02em;
        }

        .brand-tagline {
            font-size: 10px;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.3);
        }

        .left-headline {
            font-family: 'Playfair Display', serif;
            font-size: clamp(38px, 4vw, 58px);
            font-weight: 700;
            color: #fff;
            line-height: 1.1;
            margin-bottom: 20px;
        }

            .left-headline em {
                font-style: italic;
                font-weight: 400;
                color: #7ea6ff;
            }

        .left-desc {
            font-size: 14px;
            color: rgba(255,255,255,0.4);
            line-height: 1.75;
        }

        /* Decorative chart lines */
        .chart-svg {
            position: absolute;
            bottom: 0;
            right: 0;
            width: 55%;
            opacity: 0.07;
            pointer-events: none;
        }

        /* ── RIGHT FORM PANEL ── */
        .right-panel {
            width: 460px;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 48px 52px;
            background: #fff;
            border-left: 1px solid #e8ecf2;
        }

        .form-inner {
            width: 100%;
        }

        .form-eyebrow {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: #3b6cf4;
            margin-bottom: 10px;
        }

        .form-title {
            font-family: 'Playfair Display', serif;
            font-size: 34px;
            font-weight: 700;
            color: #0f172a;
            line-height: 1.1;
            margin-bottom: 6px;
        }

        .form-sub {
            font-size: 13px;
            color: #8a96a8;
            margin-bottom: 40px;
        }

        .field-group {
            margin-bottom: 20px;
        }

        .field-label {
            display: block;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: #64748b;
            margin-bottom: 8px;
        }

        .field-input {
            width: 100%;
            background: #f4f6fb;
            border: 1.5px solid #e8ecf2;
            border-radius: 10px;
            padding: 13px 16px;
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            color: #0f172a;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
        }

            .field-input::placeholder {
                color: #c4cdd8;
            }

            .field-input:focus {
                border-color: #3b6cf4;
                box-shadow: 0 0 0 3px rgba(59,108,244,0.1);
                background: #fff;
            }

        .error-box {
            background: #fff1f2;
            border: 1px solid #fda4af;
            border-radius: 10px;
            padding: 11px 16px;
            font-size: 12px;
            color: #e11d48;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .btn-signin {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #3b6cf4, #6093fa);
            border: none;
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            font-weight: 600;
            color: #fff;
            cursor: pointer;
            margin-top: 8px;
            letter-spacing: 0.02em;
            transition: opacity 0.2s, transform 0.15s;
            position: relative;
            overflow: hidden;
        }

            .btn-signin::after {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient(to bottom, rgba(255,255,255,0.1), transparent);
                pointer-events: none;
            }

            .btn-signin:hover {
                opacity: 0.9;
                transform: translateY(-1px);
            }

            .btn-signin:active {
                transform: translateY(0);
            }

        .form-footer {
            margin-top: 36px;
            padding-top: 24px;
            border-top: 1px solid #f1f5f9;
            font-size: 11px;
            color: #c4cdd8;
            display: flex;
            justify-content: space-between;
            letter-spacing: 0.05em;
        }

        @@media (max-width: 780px) {
            .left-panel {
                display: none;
            }

            .right-panel {
                width: 100%;
                border-left: none;
            }
        }
    </style>
</head>
<body>

    <!-- LEFT -->
    <div class="left-panel">
        <svg class="chart-svg" viewBox="0 0 400 300" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0,250 C80,230 130,160 200,120 C270,80 320,100 400,50" stroke="white" stroke-width="3" fill="none" />
            <path d="M0,280 C80,260 130,200 200,170 C270,140 320,150 400,110" stroke="white" stroke-width="2" fill="none" />
            <path d="M0,250 C80,230 130,160 200,120 C270,80 320,100 400,50 L400,300 L0,300 Z" fill="white" />
        </svg>

        <div class="left-content">
            <div class="brand-row">
                <div class="brand-mark">₣</div>
                <div>
                    <div class="brand-name">Finance CRM</div>
                    <div class="brand-tagline">Management Suite</div>
                </div>
            </div>

            <h1 class="left-headline">
                Smart finance,<br><em>clear decisions.</em>
            </h1>
            <p class="left-desc">
                Track accounts, manage bills, and monitor every expenditure — all from a single, unified dashboard.
            </p>
        </div>
    </div>

    <!-- RIGHT -->
    <div class="right-panel">
        <div class="form-inner">
            <div class="form-eyebrow">Secure Access</div>
            <h2 class="form-title">Welcome back.</h2>
            <p class="form-sub">Sign in to your workspace</p>

            <form method="post">
                <div class="field-group">
                    <label class="field-label">Username</label>
                    <input type="text" name="Username" class="field-input"
                           placeholder="your.username" autocomplete="username" required />
                </div>

                <div class="field-group">
                    <label class="field-label">Password</label>
                    <input type="password" name="Password" class="field-input"
                           placeholder="••••••••" autocomplete="current-password" required />
                </div>

                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="error-box">
                        <span>⚠</span> @ViewBag.ErrorMessage
                    </div>
                }

                <button type="submit" class="btn-signin">Sign In →</button>
            </form>

            <div class="form-footer">
                <span>© 2026 Finance CRM</span>
                <span>v3.1.0</span>
            </div>
        </div>
    </div>

</body>
</html>

@{
    Layout = null; // No sidebar/navbar on the login page
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Login - Financial CRM</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body {
            background: #f4f7f6;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            width: 400px;
            border: none;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        .btn-login {
            background: #2c3e50;
            color: white;
            border-radius: 8px;
            padding: 10px;
        }

            .btn-login:hover {
                background: #34495e;
                color: white;
            }
    </style>
</head>
<body>
    <div class="card login-card p-4">
        <div class="text-center mb-4">
            <h2 class="fw-bold text-dark">Financial CRM</h2>
            <p class="text-muted">Sign in to manage your finances</p>
        </div>
        <form method="post">
            <div class="mb-3">
                <label class="form-label">Username</label>
                <input type="text" name="Username" class="form-control" placeholder="Enter username" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Password</label>
                <input type="password" name="Password" class="form-control" placeholder="Enter password" required />
            </div>
            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger py-2">@ViewBag.ErrorMessage</div>
            }
            <button type="submit" class="btn btn-login w-100 mt-2">Login</button>
        </form>
    </div>
</body>
</html>